ANTHROPIC_API_KEY=
GROQ_API_KEY=
UAHP_REGISTRY_URL=http://localhost:8000
RENEE_HOME=./state
LOG_LEVEL=INFO

# LLM routing (deep turns). Override if wanted.
GROQ_MODEL=qwen/qwen3-32b
OLLAMA_MODEL=gemma4:e4b
OLLAMA_HOST=http://localhost:11434
ANTHROPIC_MODEL=claude-sonnet-4-5

# Active persona for CLI: renee or aiden
ACTIVE_PERSONA=renee

# Cognition / fringe (M16). Off by default; flip to true for the A/B.
# When enabled, PersonaCore maintains a slow per-persona FringeState
# that biases retrieval and prefixes the system prompt with a [FRINGE]
# block describing the conversation's drift (register, affect, pace,
# open threads). Persisted per-persona; loads with time-decay applied.
FRINGE_ENABLED=false
FRINGE_RETRIEVAL_WEIGHT=0.3
# FRINGE_PERSIST_PATH overrides the directory the fringe JSON lives in;
# unset means fringe files live alongside mood/identity in state_dir.
# FRINGE_PERSIST_PATH=
# Fringe trace logging path (only used when FRINGE_ENABLED=true). Defaults
# to data/fringe_traces/ relative to the working directory.
# FRINGE_TRACE_PATH=data/fringe_traces/
